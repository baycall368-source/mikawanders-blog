---
interface Props {
  href: string;
  label?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { href, label = 'Check Prices on eSIMply', size = 'md' } = Astro.props;

const styles = {
  sm: 'font-size: 0.8125rem; padding: 0.5rem 1rem;',
  md: 'font-size: 0.9375rem; padding: 0.625rem 1.25rem;',
  lg: 'font-size: 1rem; padding: 0.75rem 1.5rem;',
};
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer sponsored"
  style={`
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: #2563eb;
    color: white;
    font-weight: 600;
    border-radius: 0.5rem;
    text-decoration: none;
    box-shadow: 0 1px 3px rgba(37,99,235,0.3), 0 1px 2px rgba(37,99,235,0.2);
    transition: background 0.15s, box-shadow 0.15s;
    ${styles[size]}
  `}
>
  {label}
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M5 12h14M12 5l7 7-7 7"/>
  </svg>
</a>
