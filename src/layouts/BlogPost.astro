---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  author?: string;
  category?: string;
}

const { title, description, pubDate, updatedDate, heroImage, author = 'Mika Soren', category } = Astro.props;

const formattedPub = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedUpdated = updatedDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Country display names for the eSIM CTA
const countryNames: Record<string, string> = {
  argentina: 'Argentina', australia: 'Australia', austria: 'Austria',
  belgium: 'Belgium', brazil: 'Brazil', canada: 'Canada',
  chile: 'Chile', china: 'China', colombia: 'Colombia',
  'czech-republic': 'Czech Republic', denmark: 'Denmark', france: 'France',
  germany: 'Germany', greece: 'Greece', 'hong-kong': 'Hong Kong',
  hungary: 'Hungary', india: 'India', indonesia: 'Indonesia',
  italy: 'Italy', japan: 'Japan', kenya: 'Kenya',
  malaysia: 'Malaysia', mexico: 'Mexico', morocco: 'Morocco',
  nepal: 'Nepal', netherlands: 'Netherlands', 'new-zealand': 'New Zealand',
  norway: 'Norway', peru: 'Peru', philippines: 'Philippines',
  poland: 'Poland', portugal: 'Portugal', romania: 'Romania',
  'saudi-arabia': 'Saudi Arabia', singapore: 'Singapore', 'south-africa': 'South Africa',
  'south-korea': 'South Korea', spain: 'Spain', sweden: 'Sweden',
  switzerland: 'Switzerland', tanzania: 'Tanzania', thailand: 'Thailand',
  turkey: 'Turkey', uae: 'UAE', ukraine: 'Ukraine',
  'united-kingdom': 'United Kingdom', 'united-states': 'United States',
};

const countryDisplayName = category ? (countryNames[category] ?? null) : null;
const comparisonUrl = category ? `/best-esim-for/${category}/` : null;

const regionMap: Record<string, string> = {
  argentina: 'South America', australia: 'Oceania', austria: 'Europe',
  belgium: 'Europe', brazil: 'South America', canada: 'North America',
  chile: 'South America', china: 'Asia', colombia: 'South America',
  'czech-republic': 'Europe', denmark: 'Europe', france: 'Europe',
  germany: 'Europe', greece: 'Europe', 'hong-kong': 'Asia',
  hungary: 'Europe', india: 'Asia', italy: 'Europe', japan: 'Asia',
  malaysia: 'Asia', mexico: 'North America', morocco: 'Africa',
  nepal: 'Asia', netherlands: 'Europe', 'new-zealand': 'Oceania',
  norway: 'Europe', peru: 'South America', philippines: 'Asia',
  poland: 'Europe', portugal: 'Europe', romania: 'Europe',
  'saudi-arabia': 'Middle East', singapore: 'Asia', 'south-africa': 'Africa',
  'south-korea': 'Asia', spain: 'Europe', sweden: 'Europe',
  switzerland: 'Europe', thailand: 'Asia', turkey: 'Middle East',
  uae: 'Middle East', 'united-kingdom': 'Europe', 'united-states': 'North America',
};

const regionLabel = category ? (regionMap[category] ?? 'Travel') : 'Travel';
---

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap');

  .mika-serif { font-family: 'Playfair Display', Georgia, serif; }

  .region-pill {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #B5673F;
    background: #FAF0E8;
    padding: 0.2rem 0.6rem;
    border-radius: 2rem;
    border: 1px solid #EDD5BF;
    text-decoration: none;
  }

  .post-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.625rem, 4vw, 2.375rem);
    font-weight: 700;
    color: #1C1410;
    line-height: 1.25;
    letter-spacing: -0.025em;
    margin: 0.875rem 0 0;
  }

  .meta-bar {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    font-size: 0.875rem;
    color: #9C9088;
    padding: 1.25rem 0;
    border-top: 1px solid #EDE8E2;
    border-bottom: 1px solid #EDE8E2;
    margin: 1.5rem 0 0;
  }

  .meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #C9BFB7;
    flex-shrink: 0;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 0.75rem;
    display: block;
    margin: 2rem 0;
  }

  /* Prose overrides for blog posts — serif body text feel */
  .blog-prose {
    color: #3a3530;
    line-height: 1.8;
    font-size: 1.0625rem;
  }

  .blog-prose :global(h2) {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #1C1410;
    margin-top: 2.5rem;
    margin-bottom: 0.875rem;
    letter-spacing: -0.02em;
    border-bottom: none;
  }

  .blog-prose :global(h3) {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.1875rem;
    font-weight: 600;
    color: #1C1410;
    margin-top: 2rem;
    margin-bottom: 0.625rem;
    letter-spacing: -0.01em;
  }

  .blog-prose :global(p) {
    margin-bottom: 1.375rem;
  }

  .blog-prose :global(p:first-of-type::first-letter) {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3.25rem;
    font-weight: 700;
    color: #B5673F;
    float: left;
    line-height: 0.85;
    margin-right: 0.125rem;
    margin-top: 0.1rem;
  }

  .blog-prose :global(blockquote) {
    border-left: 3px solid #C47A5A;
    padding-left: 1.25rem;
    font-style: italic;
    color: #6B6259;
    margin: 1.75rem 0;
    font-size: 1.0625rem;
  }

  .blog-prose :global(a) {
    color: #2563eb;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .blog-prose :global(ul),
  .blog-prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .blog-prose :global(li) {
    margin-bottom: 0.375rem;
    line-height: 1.7;
  }

  .blog-prose :global(hr) {
    border: none;
    border-top: 1px solid #EDE8E2;
    margin: 2.5rem 0;
  }

  .blog-prose :global(strong) {
    font-weight: 600;
    color: #1C1410;
  }

  /* eSIM comparison CTA card */
  .esim-cta-card {
    background: #f3faf2;
    border: 1px solid #c5e0c3;
    border-radius: 0.75rem;
    padding: 1.375rem 1.5rem;
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .esim-cta-heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1C1410;
    margin: 0;
    line-height: 1.4;
  }
  .esim-cta-text {
    font-size: 0.9rem;
    color: #4a6047;
    margin: 0;
    line-height: 1.5;
  }
  .esim-cta-btn {
    display: inline-block;
    background: #6ab165;
    color: white;
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    align-self: flex-start;
    transition: background 0.15s;
  }
  .esim-cta-btn:hover { background: #5a9e55; }

  /* Author card */
  .author-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: white;
    border: 1px solid #EDE8E2;
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    margin-top: 3rem;
  }
  .author-avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #EDE8E2;
    flex-shrink: 0;
  }
  .author-name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: #1C1410;
    margin: 0 0 0.25rem;
  }
  .author-bio {
    font-size: 0.875rem;
    color: #6B6259;
    line-height: 1.6;
    margin: 0;
  }

  /* Back link */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #9C9088;
    text-decoration: none;
    transition: color 0.15s;
    margin-bottom: 2rem;
  }
  .back-link:hover { color: #B5673F; }
</style>

<BaseLayout title={title} description={description} image={heroImage}>
  <article style="max-width: 42rem; margin: 0 auto; padding: 2.5rem 1.5rem 5rem;">

    <!-- Back link -->
    <a href="/blog/" class="back-link">
      ← All posts
    </a>

    <!-- Category pill + title -->
    <span class="region-pill">{regionLabel}</span>
    <h1 class="post-title">{title}</h1>

    <!-- Meta bar -->
    <div class="meta-bar">
      <img src="/images/mika-avatar.webp" alt="Mika Soren" style="width: 1.5rem; height: 1.5rem; border-radius: 50%; object-fit: cover; border: 1.5px solid #EDE8E2;" />
      <span style="font-weight: 500; color: #6B6259;">{author}</span>
      <span class="meta-dot"></span>
      <time datetime={pubDate.toISOString()}>{formattedPub}</time>
      {formattedUpdated && (
        <>
          <span class="meta-dot"></span>
          <span>Updated {formattedUpdated}</span>
        </>
      )}
    </div>

    <!-- Hero image (if present) -->
    {heroImage && (
      <img src={heroImage} alt={title} class="hero-image" loading="eager" />
    )}

    <!-- Content -->
    <div class="blog-prose prose">
      <slot />
    </div>

    <!-- eSIM comparison CTA (auto-rendered when category matches a country) -->
    {comparisonUrl && countryDisplayName && (
      <div class="esim-cta-card">
        <p class="esim-cta-heading">Heading to {countryDisplayName}? Sort your eSIM first.</p>
        <p class="esim-cta-text">I've compared the main providers, checked the real pricing, and put together a guide on the best eSIM options for {countryDisplayName}.</p>
        <a href={comparisonUrl} class="esim-cta-btn">Best eSIM for {countryDisplayName} →</a>
      </div>
    )}

    <!-- Author card -->
    <div class="author-card">
      <img src="/images/mika-avatar.webp" alt="Mika Soren" class="author-avatar" />
      <div>
        <p class="author-name">Mika Soren</p>
        <p class="author-bio">Finnish-Australian digital nomad traveling full-time since 2019. Writing about the places, the connectivity, and the things nobody warned me about. Based: wherever my visa allows.</p>
      </div>
    </div>

  </article>
</BaseLayout>
