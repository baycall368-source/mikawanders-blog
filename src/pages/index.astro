---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const comparisons = await getCollection('comparisons');
const posts = await getCollection('blog');

const sortedComparisons = comparisons
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recentPosts = posts
  .filter(p => p.data.category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const travelTipsFeatures = [
  {
    image: '/images/ultimate-packing-list.webp',
    title: 'The ultimate packing list',
    note: 'Packing',
    href: '/blog/ultimate-packing-list/',
  },
  {
    image: '/images/solo-travel-tips.webp',
    title: 'Solo travel tips that actually help',
    note: 'Solo Travel',
    href: '/blog/solo-travel-tips/',
  },
  {
    image: '/images/how-to-avoid-jet-lag.webp',
    title: 'How to avoid jet lag',
    note: 'Flying & Airports',
    href: '/blog/how-to-avoid-jet-lag/',
  },
  {
    image: '/images/how-to-travel-on-a-budget.webp',
    title: 'How to travel on a budget',
    note: 'Budget & Planning',
    href: '/blog/how-to-travel-on-a-budget/',
  },
  {
    image: '/images/how-to-use-your-phone-abroad.webp',
    title: 'How to use your phone abroad',
    note: 'Travel Apps & Tools',
    href: '/blog/how-to-use-your-phone-abroad/',
  },
  {
    image: '/images/how-to-become-a-digital-nomad.webp',
    title: 'How to become a digital nomad',
    note: 'Digital Nomad',
    href: '/blog/how-to-become-a-digital-nomad/',
  },
];

// Featured travel snapshots — personal, not eSIM-related
const travelFeatures = [
  {
    image: '/images/france-travel-guide.webp',
    country: 'France',
    note: 'Three times to Paris, a slow month in Lyon, one genuinely great trip through Provence. Still thinking about a farmhouse outside Apt.',
    href: '/blog/france-travel-guide/',
  },
  {
    image: '/images/best-esim-for-spain-sagrada-familia.webp',
    country: 'Spain',
    note: 'Barcelona twice. Madrid once by accident. A whole month in Andalusia working remotely with 4G that had absolutely no business being that good.',
    href: '/blog/spain-travel-guide/',
  },
  {
    image: '/images/best-esim-for-japan-fushimi-inari.webp',
    country: 'Japan',
    note: 'The country that broke my ability to eat bad food anywhere else. Three trips and counting.',
    href: '/blog/japan-travel-guide/',
  },
  {
    image: '/images/thailand-travel-guide.webp',
    country: 'Thailand',
    note: 'Chiang Mai for a month, Bangkok for a week, Pai for longer than planned. The north is the part everyone forgets to mention.',
    href: '/blog/thailand-travel-guide/',
  },
  {
    image: '/images/best-esim-for-italy-colosseum.webp',
    country: 'Italy',
    note: 'Rome three times, a week in Naples eating nothing but pizza, and a slow drive through Sicily I think about constantly.',
    href: '/blog/italy-travel-guide/',
  },
  {
    image: '/images/australia-travel-guide.webp',
    country: 'Australia',
    note: 'I grew up here, left in 2019, and go back once a year. Still not sure whether that makes me a traveler or just someone who moved.',
    href: '/blog/australia-travel-guide/',
  },
];
---

<BaseLayout
  title="Mika Wanders | Travel Blog by a Full-Time Nomad"
  description="I left a perfectly good dev job in Melbourne in 2019 for what was supposed to be a three-month trip. It's been five years. This is where I write about it."
>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap');

  .mika-serif { font-family: 'Playfair Display', Georgia, serif; }

  .section-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #C47A5A;
    margin-bottom: 0.5rem;
    display: block;
  }

  /* Travel feature cards */
  .feature-card {
    display: block;
    text-decoration: none;
    position: relative;
    border-radius: 0.875rem;
    overflow: hidden;
    cursor: pointer;
  }
  .feature-card img {
    width: 100%;
    height: 20rem;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
    border-radius: 0.875rem;
  }
  .feature-card:hover img {
    transform: scale(1.03);
  }
  .feature-card-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 2rem 1.5rem 1.5rem;
    background: linear-gradient(to top, rgba(28,20,16,0.82) 0%, rgba(28,20,16,0.3) 60%, transparent 100%);
    border-radius: 0 0 0.875rem 0.875rem;
  }

  /* Review list */
  .review-link {
    color: #6B6259;
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.15s;
    white-space: nowrap;
    cursor: pointer;
  }
  .review-link:hover { color: #C47A5A; }

  /* Blog rows */
  .post-row {
    display: block;
    padding: 1.25rem 0;
    text-decoration: none;
    border-bottom: 1px solid #EDE8E2;
  }
  .post-row:last-child { border-bottom: none; }
  .post-row:hover .post-title { color: #C47A5A; }

  @media (max-width: 900px) {
    .features-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 640px) {
    .hero-inner { flex-direction: column; align-items: center; text-align: center; }
    .hero-buttons { justify-content: center; }
    .features-grid { grid-template-columns: 1fr !important; }
  }
</style>

  <!-- ── HERO ──────────────────────────────────────────────────────────── -->
  <section style="background: #FAF8F4; border-bottom: 1px solid #EDE8E2; padding: 4rem 1.5rem;">
    <div class="hero-inner" style="max-width: 52rem; margin: 0 auto; display: flex; align-items: center; gap: 3rem;">

      <div style="flex-shrink: 0;">
        <img
          src="/images/mika-avatar.webp"
          alt="Mika Soren"
          style="width: 9rem; height: 9rem; border-radius: 50%; object-fit: cover; border: 4px solid #EDE8E2; box-shadow: 0 4px 20px rgba(28,20,16,0.10);"
        />
      </div>

      <div>
        <span class="section-label">mikawanders.blog</span>
        <h1 class="mika-serif" style="font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 700; color: #1C1410; margin: 0 0 1rem; line-height: 1.2; letter-spacing: -0.02em;">
          Hey, I'm Mika.
        </h1>
        <p style="color: #6B6259; line-height: 1.8; font-size: 1rem; margin: 0 0 1.5rem; max-width: 30rem;">
          I left a perfectly good dev job in Melbourne in 2019 for what was supposed to be a three-month trip.
          <br /><br />
          It's been five years. (My mum has stopped asking.)
          <br /><br />
          I move slow, stay long, and try to eat whatever the locals are eating.
        </p>
        <div class="hero-buttons" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          <a href="/about/" style="display: inline-block; background: #1C1410; color: #FAF8F4; font-size: 0.875rem; font-weight: 600; padding: 0.625rem 1.375rem; border-radius: 2rem; text-decoration: none; letter-spacing: 0.01em; cursor: pointer;">
            About Me
          </a>
          <a href="/best-esim-for/france/" style="display: inline-block; background: transparent; color: #1C1410; font-size: 0.875rem; font-weight: 600; padding: 0.625rem 1.375rem; border-radius: 2rem; text-decoration: none; border: 1.5px solid #C4B5A8; letter-spacing: 0.01em; cursor: pointer;">
            Browse Guides
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ── PULL QUOTE ────────────────────────────────────────────────────── -->
  <section style="background: #F3EFE9; border-bottom: 1px solid #EDE8E2; padding: 2.25rem 1.5rem; text-align: center;">
    <p class="mika-serif" style="font-size: 1.125rem; font-style: italic; color: #6B6259; margin: 0 auto; max-width: 38rem; line-height: 1.7;">
      "47 countries. One backpack. Extremely strong opinions about airport Wi-Fi."
    </p>
  </section>

  <!-- ── WHERE I'VE BEEN ───────────────────────────────────────────────── -->
  <section style="padding: 4rem 1.5rem; max-width: 56rem; margin: 0 auto;">

    <div style="margin-bottom: 2rem;">
      <span class="section-label">Field Notes</span>
      <h2 class="mika-serif" style="font-size: 1.875rem; font-weight: 700; color: #1C1410; margin: 0 0 0.5rem; letter-spacing: -0.02em;">
        Where I've Been
      </h2>
      <p style="color: #9C9088; font-size: 0.9375rem; margin: 0;">
        Five years in. Still no plans to stop.
      </p>
    </div>

    <div class="features-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;">
      {travelFeatures.map(feature => {
        const inner = (
          <>
            <div style={`width: 100%; height: 20rem; background: #D4C9BC; border-radius: 0.875rem; overflow: hidden;`}>
              <img src={feature.image} alt={feature.country} loading="lazy" style="width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease;" onerror="this.style.display='none'" />
            </div>
            <div class="feature-card-overlay">
              <p class="mika-serif" style="font-size: 1.125rem; font-weight: 600; color: #FAF8F4; margin: 0 0 0.375rem; line-height: 1.3;">
                {feature.country}
              </p>
              <p style="font-size: 0.8125rem; color: rgba(250,248,244,0.8); margin: 0; line-height: 1.55;">
                {feature.note}
              </p>
            </div>
          </>
        );
        return feature.href
          ? <a class="feature-card" href={feature.href}>{inner}</a>
          : <div class="feature-card">{inner}</div>;
      })}
    </div>

  </section>

  <!-- ── FROM THE BLOG ─────────────────────────────────────────────────── -->
  {recentPosts.length > 0 && (
    <section style="padding: 4rem 1.5rem 5rem; max-width: 56rem; margin: 0 auto;">

      <div style="margin-bottom: 2rem;">
        <span class="section-label">From the Blog</span>
        <h2 class="mika-serif" style="font-size: 1.875rem; font-weight: 700; color: #1C1410; margin: 0; letter-spacing: -0.02em;">
          Latest Writing
        </h2>
      </div>

      <div>
        {recentPosts.map(post => (
          <a class="post-row" href={`/blog/${post.id}/`}>
            <h3 class="post-title mika-serif" style="font-size: 1.0625rem; font-weight: 600; color: #1C1410; margin: 0 0 0.3rem; transition: color 0.15s; line-height: 1.4;">
              {post.data.title}
            </h3>
            <p style="font-size: 0.875rem; color: #9C9088; margin: 0; line-height: 1.5;">
              {post.data.description}
            </p>
          </a>
        ))}
      </div>

    </section>
  )}

  <!-- ── TRAVEL TIPS ──────────────────────────────────────────────────── -->
  <section style="padding: 0 1.5rem 5rem; max-width: 56rem; margin: 0 auto;">

    <div style="margin-bottom: 2rem; display: flex; align-items: baseline; justify-content: space-between;">
      <div>
        <span class="section-label">Travel Tips</span>
        <h2 class="mika-serif" style="font-size: 1.875rem; font-weight: 700; color: #1C1410; margin: 0; letter-spacing: -0.02em;">
          Practical stuff
        </h2>
      </div>
      <a href="/travel-tips/" style="font-size: 0.8125rem; font-weight: 600; color: #2563eb; text-decoration: none; white-space: nowrap;">
        All tips →
      </a>
    </div>

    <div class="features-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;">
      {travelTipsFeatures.map(tip => (
        <a class="feature-card" href={tip.href}>
          <div style="width: 100%; height: 20rem; background: #D4C9BC; border-radius: 0.875rem; overflow: hidden;">
            <img src={tip.image} alt={tip.title} loading="lazy" style="width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease;" onerror="this.style.display='none'" />
          </div>
          <div class="feature-card-overlay">
            <p style="font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(250,248,244,0.7); margin: 0 0 0.3rem;">
              {tip.note}
            </p>
            <p class="mika-serif" style="font-size: 1rem; font-weight: 600; color: #FAF8F4; margin: 0; line-height: 1.3;">
              {tip.title}
            </p>
          </div>
        </a>
      ))}
    </div>

  </section>

  <!-- ── REVIEWS (understated) ─────────────────────────────────────────── -->
  {sortedComparisons.length > 0 && (
    <section style="background: #F3EFE9; border-top: 1px solid #EDE8E2; border-bottom: 1px solid #EDE8E2; padding: 2.25rem 1.5rem;">
      <div style="max-width: 56rem; margin: 0 auto; display: flex; align-items: baseline; gap: 2rem; flex-wrap: wrap;">

        <div style="flex-shrink: 0;">
          <span class="section-label" style="margin-bottom: 0.15rem;">eSIM Reviews</span>
          <p class="mika-serif" style="font-size: 1rem; font-style: italic; color: #9C9088; margin: 0; white-space: nowrap;">Tested. Priced. Ranked.</p>
        </div>

        <div style="display: flex; flex-wrap: wrap; gap: 0.375rem 0; align-items: center; flex: 1;">
          {sortedComparisons.map((post, i) => (
            <span style="display: inline-flex; align-items: center;">
              <a class="review-link" href={`/best-esim-for/${post.id}/`}>
                {post.data.country}
              </a>
              {i < sortedComparisons.length - 1 && (
                <span style="color: #C4B5A8; margin: 0 0.5rem; font-size: 0.75rem;">·</span>
              )}
            </span>
          ))}
        </div>

      </div>
    </section>
  )}

</BaseLayout>
